{
    "name": "ez-php/health",
    "version": "1.7.1",
    "description": "Lightweight health-check endpoint for the ez-php framework — DB, Redis, and Queue probes with a JSON /health response",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Uretschnig",
            "email": "andreas.uretschnig@gmail.com"
        }
    ],
    "keywords": [
        "health",
        "health-check",
        "monitoring",
        "probe",
        "php",
        "framework",
        "ez-php"
    ],
    "homepage": "https://github.com/ez-php/health",
    "support": {
        "issues": "https://github.com/ez-php/health/issues",
        "source": "https://github.com/ez-php/health"
    },
    "require": {
        "php": "^8.5",
        "ez-php/contracts": "^1.0",
        "ez-php/framework": "^1.0",
        "ez-php/http": "^1.0"
    },
    "require-dev": {
        "ez-php/docker": "^1.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\Health\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
